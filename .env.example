# CyberGuard Environment Variables
# Copy this to .env and fill in real values for production

SECRET_KEY=change-this-to-a-random-64-char-string-in-production

# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///cyberguard.db

# MySQL (uncomment and fill to switch):
# DATABASE_URL=mysql+pymysql://root:yourpassword@localhost/cyberguard_db

# Email (leave blank to print OTPs to terminal in dev mode):
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_FROM=noreply@cyberguard.local
